generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model actividadprograma {
  id                            Int       @id @default(autoincrement())
  evento_id                     Int
  tipoActividad                 String    @db.VarChar(45)
  nombreActividad               String    @db.VarChar(255)
  descripcionActividad          String    @db.VarChar(450)
  nombreSalaEspacio             String    @db.VarChar(155)
  capacidadPersonasSala         Int       @db.SmallInt
  fechaActividad                DateTime  @db.Date
  horaInicioActividad           DateTime  @db.Time(6)
  horaFinActividad              DateTime  @db.Time(6)
  nombreCompletoPilaExpositor   String?   @db.VarChar(450)
  organizacionDelExpositor      String?   @db.VarChar(150)
  urlImagenBannerActividad      String?   @db.VarChar(505)
  estadoActividad               String    @db.VarChar(45)
  latitudPresencial             Decimal?  @db.Decimal(10, 8)
  longitudPresencial            Decimal?  @db.Decimal(11, 8)
  direccion_texto               String?   @db.VarChar(205)
  linkReunionVirtual            String?   @db.VarChar(505)
  ubicacionGoogleMapsPresencial String?   @db.VarChar(505)
  estaActivo                    Int       @default(1) @db.SmallInt
  fechaCreacion                 DateTime  @default(now()) @db.Timestamp(6)
  creadoModificadoFecha         DateTime? @db.Timestamp(6)
  evento                        evento    @relation(fields: [evento_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_actividadprograma_evento1")

  @@index([evento_id], map: "fk_actividadprograma_evento1_idx")
}

model ciudad {
  id      Int       @id @default(autoincrement())
  pais_id Int
  nombre  String    @db.VarChar(45)
  pais    pais      @relation(fields: [pais_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_ciudad_pais1")
  empresa empresa[]

  @@index([pais_id], map: "fk_ciudad_pais1_idx")
}

model empresa {
  id                      Int               @id @default(autoincrement())
  ciudad_id               Int
  nombre                  String            @db.VarChar(55)
  rubro                   String            @db.VarChar(55)
  sitioWeb                String?           @db.VarChar(300)
  descripcion             String?           @db.VarChar(105)
  telefonoWhatsapp        String            @db.VarChar(45)
  correoCorporativo       String            @db.VarChar(105)
  urlFotoPerfil           String?           @db.VarChar(500)
  urlPdf                  String?           @db.VarChar(500)
  estaActivo              Int               @default(1)
  fechaCreacion           DateTime          @default(now()) @db.Timestamp(6)
  creado_modificado_fecha DateTime?         @db.Timestamp(6)
  ciudad                  ciudad            @relation(fields: [ciudad_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_empresa_ciudad1")
  empresa_usuario         empresa_usuario[]
  empresaevento           empresaevento[]

  @@index([ciudad_id], map: "fk_empresa_ciudad1_idx")
}

model empresa_usuario {
  id               Int                @id @default(autoincrement())
  empresa_id       Int
  usuario_id       Int
  empresaevento_id Int
  cargo            String             @db.VarChar(55)
  esResponsable    Int                @db.SmallInt
  empresa          empresa            @relation(fields: [empresa_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_empresa_usuario_empresa")
  empresaevento    empresaevento      @relation(fields: [empresaevento_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_empresa_usuario_empresaevento1")
  usuario          usuario            @relation(fields: [usuario_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_empresa_usuario_usuario1")
  resultadoreunion resultadoreunion[]
  solicitudreunion solicitudreunion[]

  @@index([empresa_id], map: "fk_empresa_usuario_empresa_idx")
  @@index([empresaevento_id], map: "fk_empresa_usuario_empresaevento1_idx")
  @@index([usuario_id], map: "fk_empresa_usuario_usuario1_idx")
}

model empresaevento {
  id                                                                            Int                         @id @default(autoincrement())
  empresa_id                                                                    Int
  evento_id                                                                     Int
  tipoParticipacion                                                             String                      @db.VarChar(75)
  estadoHabilitacionAcceso                                                      String                      @db.VarChar(45)
  motivoRechazoAcceso                                                           String?                     @db.VarChar(500)
  montoPagado                                                                   Decimal?                    @db.Decimal(10, 2)
  estadoVerificacionPago                                                        String                      @db.VarChar(45)
  fechaHoraEnvioComprobante                                                     DateTime?                   @db.Timestamp(6)
  fechaHoraVerificacionPago                                                     DateTime?                   @db.Timestamp(6)
  observacionSobreComprobante                                                   String?                     @db.VarChar(505)
  numeroParticipantes                                                           Int                         @db.SmallInt
  estaActivo                                                                    Int                         @default(1) @db.SmallInt
  fechaCreacion                                                                 DateTime                    @default(now()) @db.Timestamp(6)
  creadoModificadoFecha                                                         DateTime?                   @db.Timestamp(6)
  empresa_usuario                                                               empresa_usuario[]
  empresa                                                                       empresa                     @relation(fields: [empresa_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_empresaevento_empresa1")
  evento                                                                        evento                      @relation(fields: [evento_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_empresaevento_evento1")
  empresaeventocomprobantes                                                     empresaeventocomprobantes[]
  notificacion                                                                  notificacion[]
  resultadoreunion_resultadoreunion_empresaeventoCalificadora_idToempresaevento resultadoreunion[]          @relation("resultadoreunion_empresaeventoCalificadora_idToempresaevento")
  resultadoreunion_resultadoreunion_empresaeventoCalificada_idToempresaevento   resultadoreunion[]          @relation("resultadoreunion_empresaeventoCalificada_idToempresaevento")
  solicitudreunion_solicitudreunion_empresaEvento_idToempresaevento             solicitudreunion[]          @relation("solicitudreunion_empresaEvento_idToempresaevento")
  solicitudreunion_solicitudreunion_empresaEventorReceptora_idToempresaevento   solicitudreunion[]          @relation("solicitudreunion_empresaEventorReceptora_idToempresaevento")

  @@index([empresa_id], map: "fk_empresaevento_empresa1_idx")
  @@index([evento_id], map: "fk_empresaevento_evento1_idx")
}

model empresaeventocomprobantes {
  id                            Int           @id @default(autoincrement())
  empresaEvento_id              Int
  urlComprobantePagoInscripcion String        @db.VarChar(505)
  estaActivo                    Int           @default(1) @db.SmallInt
  fechaCreacion                 DateTime      @default(now()) @db.Timestamp(6)
  creadoModificadoFecha         DateTime?     @db.Timestamp(6)
  empresaevento                 empresaevento @relation(fields: [empresaEvento_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_empresaeventocomprobantes_empresaevento1")

  @@index([empresaEvento_id], map: "fk_empresaeventocomprobantes_empresaevento1_idx")
}

model evento {
  id                             Int                 @id @default(autoincrement())
  nombre                         String              @db.VarChar(205)
  edicion                        String              @db.VarChar(45)
  descripcion                    String?             @db.VarChar(505)
  fechaInicioEvento              DateTime            @db.Timestamp(6)
  fechaFinEvento                 DateTime            @db.Timestamp(6)
  duracionReunion                Int                 @db.SmallInt
  tiempoEntreReuniones           Int                 @db.SmallInt
  cantidadTotalMesasEvento       Int                 @db.SmallInt
  capacidadPersonasPorMesa       Int                 @db.SmallInt
  montoBaseIncripcionBolivianos  Decimal             @db.Decimal(10, 2)
  cantidadParticipantesIncluidos Int                 @db.SmallInt
  costoParticipanteExtra         Int                 @db.SmallInt
  urlImagenMapaRecinto           String?             @db.VarChar(505)
  urlImagenCronogramaCharlas     String?             @db.VarChar(505)
  urlLogoEvento                  String?             @db.VarChar(505)
  sobreElEvento                  String?             @db.VarChar(2000)
  correoContacto                 String?             @db.VarChar(105)
  telefonoContacto               String?             @db.VarChar(45)
  enlaceFacebook                 String?             @db.VarChar(505)
  enlaceInstagram                String?             @db.VarChar(505)
  enlaceTwitterX                 String?             @db.VarChar(505)
  ciudadEvento                   String?             @db.VarChar(205)
  paisEvento                     String?             @db.VarChar(105)
  estaActivo                     Int                 @db.SmallInt
  esPrincipal                    Int                 @default(0) @db.SmallInt
  fechaCreacion                  DateTime            @default(now()) @db.Timestamp(6)
  creadoModificadoFecha          DateTime?           @db.Timestamp(6)
  actividadprograma              actividadprograma[]
  empresaevento                  empresaevento[]
  eventoreglaqr                  eventoreglaqr[]
  mesa                           mesa[]
  noticia                        noticia[]
  reunion                        reunion[]
  usuario                        usuario[]
}

model eventoreglaqr {
  id                Int       @id @default(autoincrement())
  evento_id         Int
  rangoDesde        Int       @db.SmallInt
  rangoHasta        Int       @db.SmallInt
  monto             Decimal   @db.Decimal(10, 2)
  urlQR             String    @db.VarChar(500)
  estadoActivo      Int       @default(1) @db.SmallInt
  fechaCreacion     DateTime  @default(now()) @db.Timestamp(6)
  fechaModificacion DateTime? @db.Timestamp(6)
  evento            evento    @relation(fields: [evento_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_eventoreglaqr_evento1")

  @@index([evento_id], map: "fk_eventoreglaqr_evento1_idx")
}

model mesa {
  id                    Int          @id @default(autoincrement())
  evento_id             Int
  numeroMesa            Int          @db.SmallInt
  capacidadPersonas     Int          @db.SmallInt
  estaActivo            Int          @default(1) @db.SmallInt
  fechaCreacion         DateTime     @default(now()) @db.Timestamp(6)
  creadoModificadoFecha DateTime?    @db.Timestamp(6)
  evento                evento       @relation(fields: [evento_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_mesa_evento1")
  mesabloque            mesabloque[]
  reunion               reunion[]

  @@index([evento_id], map: "fk_mesa_evento1_idx")
}

model mesabloque {
  id                    Int       @id @default(autoincrement())
  mesa_id               Int
  reunion_id            Int?
  fechaHoraInicio       DateTime  @db.Timestamp(6)
  fechaHoraFin          DateTime? @db.Timestamp(6)
  estaOcupado           Int       @db.SmallInt
  estaActivo            Int       @default(1) @db.SmallInt
  fechaCreacion         DateTime  @default(now()) @db.Timestamp(6)
  creadoModificadoFecha DateTime? @db.Timestamp(6)
  mesa                  mesa      @relation(fields: [mesa_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_mesabloque_mesa1")
  reunion               reunion?  @relation(fields: [reunion_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_mesabloque_reunion1")

  @@index([mesa_id], map: "fk_mesabloque_mesa1_idx")
  @@index([reunion_id], map: "fk_mesabloque_reunion1_idx")
}

model noticia {
  id                    Int       @id @default(autoincrement())
  evento_id             Int
  usuario_id            Int
  tituloNoticia         String    @db.VarChar(105)
  contenidoNoticia      String    @db.VarChar(500)
  urlImagenNoticia      String?   @db.VarChar(500)
  tipoNoticia           String    @db.VarChar(45)
  estadoPublicacion     String    @db.VarChar(45)
  fechaHoraPublicacion  DateTime  @db.Timestamp(6)
  estaActivo            Int       @default(1) @db.SmallInt
  fechaCreacion         DateTime  @default(now()) @db.Timestamp(6)
  creadoModificadoFecha DateTime? @db.Timestamp(6)
  evento                evento    @relation(fields: [evento_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_noticia_evento1")
  usuario               usuario   @relation(fields: [usuario_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_noticia_usuario1")

  @@index([evento_id], map: "fk_noticia_evento1_idx")
  @@index([usuario_id], map: "fk_noticia_usuario1_idx")
}

model notificacion {
  id                    Int           @id @default(autoincrement())
  empresaevento_id      Int
  tituloNotificacion    String        @db.VarChar(300)
  mensajeNotificacion   String        @db.VarChar(500)
  tipoNotificacion      String        @db.VarChar(45)
  referenciaId          Int
  referenciaNombreTabla String        @db.VarChar(65)
  haSidoLeida           Int           @db.SmallInt
  estaActivo            Int           @db.SmallInt
  fechaCreacion         DateTime      @default(now()) @db.Timestamp(6)
  creadoModificadoFecha DateTime?     @db.Timestamp(6)
  empresaevento         empresaevento @relation(fields: [empresaevento_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_notificacion_empresaevento2")

  @@index([empresaevento_id], map: "fk_notificacion_empresaevento2_idx")
}

model pais {
  id     Int      @id @default(autoincrement())
  nombre String   @db.VarChar(45)
  ciudad ciudad[]
}

model resultadoreunion {
  id                                                                         Int             @id @default(autoincrement())
  reunion_id                                                                 Int
  empresaeventoCalificadora_id                                               Int
  empresaeventoCalificada_id                                                 Int
  empresa_usuario_id                                                         Int
  calificacionReunion                                                        Int             @db.SmallInt
  rangoAcuerdoComercial                                                      String          @db.VarChar(45)
  observacionesPuntosTratados                                                String          @db.VarChar(505)
  estaActivo                                                                 Int             @default(1) @db.SmallInt
  fechaCreacion                                                              DateTime        @default(now()) @db.Timestamp(6)
  creadoModificadoFecha                                                      DateTime?       @db.Timestamp(6)
  empresa_usuario                                                            empresa_usuario @relation(fields: [empresa_usuario_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_resultadoreunion_empresa_usuario1")
  empresaevento_resultadoreunion_empresaeventoCalificadora_idToempresaevento empresaevento   @relation("resultadoreunion_empresaeventoCalificadora_idToempresaevento", fields: [empresaeventoCalificadora_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_resultadoreunion_empresaevento1")
  empresaevento_resultadoreunion_empresaeventoCalificada_idToempresaevento   empresaevento   @relation("resultadoreunion_empresaeventoCalificada_idToempresaevento", fields: [empresaeventoCalificada_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_resultadoreunion_empresaevento2")
  reunion                                                                    reunion         @relation(fields: [reunion_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_resultadoreunion_reunion1")

  @@index([empresa_usuario_id], map: "fk_resultadoreunion_empresa_usuario1_idx")
  @@index([empresaeventoCalificadora_id], map: "fk_resultadoreunion_empresaevento1_idx")
  @@index([empresaeventoCalificada_id], map: "fk_resultadoreunion_empresaevento2_idx")
  @@index([reunion_id], map: "fk_resultadoreunion_reunion1_idx")
}

model reunion {
  id                            Int                @id @default(autoincrement())
  solicitudReunion_id           Int
  mesa_id                       Int
  evento_id                     Int
  tipoReunion                   String             @db.VarChar(45)
  fechaHoraInicioReunion        DateTime           @db.Timestamp(6)
  fechaHoraFinReunion           DateTime           @db.Timestamp(6)
  estadoReunion                 String             @db.VarChar(45)
  observacionesReunion          String?            @db.VarChar(505)
  seEnvioNotificacionDeRetraso  Int                @db.SmallInt
  cantidadAsistentesRegistrados Int                @db.SmallInt
  estaActivo                    Int                @default(1) @db.SmallInt
  fechaCreacion                 DateTime           @default(now()) @db.Timestamp(6)
  creadoModificadoFecha         DateTime?          @db.Timestamp(6)
  mesabloque                    mesabloque[]
  resultadoreunion              resultadoreunion[]
  evento                        evento             @relation(fields: [evento_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_reunion_evento1")
  mesa                          mesa               @relation(fields: [mesa_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_reunion_mesa1")
  solicitudreunion              solicitudreunion   @relation(fields: [solicitudReunion_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_reunion_solicitudreunion1")

  @@index([evento_id], map: "fk_reunion_evento1_idx")
  @@index([mesa_id], map: "fk_reunion_mesa1_idx")
  @@index([solicitudReunion_id], map: "fk_reunion_solicitudreunion1_idx")
}

model solicitudreunion {
  id                                                                       Int             @id @default(autoincrement())
  empresaEvento_id                                                         Int
  empresaEventorReceptora_id                                               Int
  empresa_usuarioResponsableSolicitud                                      Int
  tipoReunion                                                              String          @db.VarChar(55)
  enlaceReunionVirtual                                                     String?         @db.VarChar(500)
  ubicacionGoogleMapsReunion                                               String?         @db.VarChar(500)
  latitudPresencial                                                        Decimal?        @db.Decimal(10, 8)
  longitudPresencial                                                       Decimal?        @db.Decimal(11, 8)
  direccionTexto                                                           String?         @db.VarChar(205)
  fechaHoraInicioPropuesta                                                 DateTime        @db.Timestamp(6)
  fechaHoraFinPropuesta                                                    DateTime        @db.Timestamp(6)
  mensajeParaEmpresaReceptora                                              String?         @db.VarChar(505)
  estadoSolicitud                                                          String          @db.VarChar(45)
  motivoRechazoSolicitud                                                   String?         @db.VarChar(505)
  estaActivo                                                               Int             @default(1) @db.SmallInt
  fechaCreacion                                                            DateTime?       @default(now()) @db.Timestamp(6)
  creadoModificadoFecha                                                    DateTime?       @db.Timestamp(6)
  reunion                                                                  reunion[]
  empresa_usuario                                                          empresa_usuario @relation(fields: [empresa_usuarioResponsableSolicitud], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_solicitudreunion_empresa_usuario1")
  empresaevento_solicitudreunion_empresaEvento_idToempresaevento           empresaevento   @relation("solicitudreunion_empresaEvento_idToempresaevento", fields: [empresaEvento_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_solicitudreunion_empresaevento1")
  empresaevento_solicitudreunion_empresaEventorReceptora_idToempresaevento empresaevento   @relation("solicitudreunion_empresaEventorReceptora_idToempresaevento", fields: [empresaEventorReceptora_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_solicitudreunion_empresaevento2")

  @@index([empresa_usuarioResponsableSolicitud], map: "fk_solicitudreunion_empresa_usuario1_idx")
  @@index([empresaEvento_id], map: "fk_solicitudreunion_empresaevento1_idx")
  @@index([empresaEventorReceptora_id], map: "fk_solicitudreunion_empresaevento2_idx")
}

model usuario {
  id                    Int               @id @default(autoincrement())
  evento_id             Int?
  nombres               String            @db.VarChar(105)
  apellidoPaterno       String            @db.VarChar(65)
  apellidoMaterno       String?           @db.VarChar(65)
  correo                String            @db.VarChar(105)
  contrasenia           String            @db.VarChar(105)
  telefono              String            @db.VarChar(45)
  urlFotoPerfil         String            @db.VarChar(505)
  rolEvento             String            @db.VarChar(45)
  estaActivo            Int               @default(1)
  fechaCreacion         DateTime          @default(now()) @db.Timestamp(6)
  creadoModificadoFecha DateTime?         @db.Timestamp(6)
  empresa_usuario       empresa_usuario[]
  noticia               noticia[]
  evento                evento?           @relation(fields: [evento_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_usuario_evento1")

  @@index([evento_id], map: "fk_usuario_evento1_idx")
}
